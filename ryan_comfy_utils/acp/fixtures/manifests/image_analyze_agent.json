{
  "node_id": "ryan.acp.image_analyze_agent",
  "skill_id": "image_prompt_reverse",
  "mode": "fixed",
  "context_template": "系统已将目标 Skill 目录配置为: {skill_directory}\n请优先通过工具读取并学习其中的 SKILL.md 以及相关规则文件，然后严格按照其中的规则执行以下用户任务。\n\n用户输入:\n{input.text}\n\n参考图路径:\n{input.images}\n",
  "input_contract": {
    "text": true,
    "images": true,
    "files": false
  },
  "output_contract": {
    "type": "text",
    "fields": ["response_text", "raw_result_json"]
  },
  "result_mapping": {
    "response_text": "outputs.response_text",
    "raw_result_json": "raw_result_json"
  }
}