{
  "node_id": "ryan.acp.image_analyze_agent",
  "skill_id": "image_prompt_reverse",
  "mode": "fixed",
  "context_template": "读取 Skill:\n{skill_directory}\n\n用户输入:\n{input.text}\n\n参考图路径:\n{input.images}\n",
  "input_contract": {
    "text": true,
    "images": true,
    "files": false
  },
  "output_contract": {
    "type": "text",
    "fields": ["response_text", "raw_result_json"]
  },
  "result_mapping": {
    "response_text": "outputs.response_text",
    "raw_result_json": "raw_result_json"
  }
}